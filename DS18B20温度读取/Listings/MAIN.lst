  67          float ds18b20_readt(void)//读取温度
  68          {
  69   1          unsigned char tlsb,tmlb;
  70   1          int temp;
  71   1          float t;
  72   1          onewire_init();//单总线初始化：建立通信的前提
  73   1          one_sendbyte(DS18B20_CMD_SKIP_ROM);
  74   1          one_sendbyte(DS18B20_CMD_READ_SCRATCHPAD);//告诉传感器 “要读温度数据了”
  75   1          tlsb = one_receivebyte();// 先读低8位（暂存器第0字节）
  76   1          tmlb = one_receivebyte();// 后读高8位（暂存器第1字节）
  77   1          temp = (tmlb<<8)|tlsb;//把两个 8 位字节合成完整的温度数据
  78   1          t = temp/16.0;//把原始数据转换成可读的浮点温度
  79   1          return t;
  80   1      }
